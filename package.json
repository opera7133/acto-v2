{
  "name": "acto-v2",
  "devDependencies": {
    "prettier": "3.8.5"
  },
  "private": true,
  "scripts": {
    "dev": "bun run --parallel dev:blog dev:cms",
    "dev:blog": "bun run --filter blog dev",
